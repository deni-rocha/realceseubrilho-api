# =============================================================================
# CONFIGURAÇÕES DE AMBIENTE - EXEMPLO SEGURO
# =============================================================================
# Copie este arquivo para .env.development ou .env.production
# e preencha com suas credenciais reais
# =============================================================================

NODE_ENV=development

# =============================================================================
# BANCO DE DADOS MYSQL
# =============================================================================
DB_HOST="localhost"
DB_USERNAME="seu_usuario_mysql"
DB_PASSWORD="sua_senha_mysql"
DB_DATABASE="realceseubrilho"
DB_PORT=3306

# =============================================================================
# BANCO DE DADOS POSTGRESQL (Desenvolvimento Local - Docker)
# =============================================================================
DEV_DATABASE_URL="postgres://usuario:senha@localhost:5432/realcestore"

# =============================================================================
# JWT - JSON WEB TOKEN
# =============================================================================
# Gere uma secret forte: openssl rand -base64 32
JWT_SECRET="gerar_nova_secret_aqui_use_openssl_rand_base64_32"

# =============================================================================
# USUÁRIO ADMINISTRADOR PADRÃO
# =============================================================================
ADMIN_EMAIL="admin@seudominio.com"
ADMIN_PASSWORD="mudar_na_primeira_execucao"
ADMIN_NAME="Administrador"

# =============================================================================
# CLOUDINARY (Upload de Imagens)
# =============================================================================
CLOUDINARY_CLOUD_NAME="sua_cloud_name"
CLOUDINARY_API_KEY="sua_api_key"
CLOUDINARY_API_SECRET="sua_api_secret"

# =============================================================================
# CONFIGURAÇÕES DE EMAIL (SMTP)
# =============================================================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="seu_email@gmail.com"
SMTP_PASS="sua_senha_de_aplicativo"
FRONTEND_URL="http://localhost:5173"
SUPPORT_EMAIL="suporte@seudominio.com"

# =============================================================================
# WHATSAPP - NÚMERO DE CONTATO
# =============================================================================
WHATSAPP_CONTACT_NUMBER="5500000000000"

# =============================================================================
# CORS - ORIGENS PERMITIDAS
# =============================================================================
CORS_ORIGINS="https://seudominio.com,http://localhost:3000,http://localhost:5173"

# =============================================================================
# PORTA DA APLICAÇÃO
# =============================================================================
PORT="3000"
